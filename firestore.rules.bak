rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Product
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'brand', 'quantity', 'imageUrl', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.price is string && data.price.size() <= 100
        && data.category is string && data.category.size() <= 100
        && data.brand is string && data.brand.size() <= 100
        && data.quantity is number && data.quantity >= 0
        && data.imageUrl is string && data.imageUrl.size() <= 950000
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() 
        && request.resource.data.keys().hasAll(['name', 'description', 'price', 'category', 'brand', 'quantity', 'imageUrl', 'createdAt', 'updatedAt'])
        && request.resource.data.updatedAt == request.time
        && request.resource.data.createdAt == resource.data.createdAt; // Immutable createdAt
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      // ONLY the Super Admin can create/delete other admin records
      allow write: if isSignedIn() && request.auth.token.email == "mirmuntasiralamehad@gamil.con";
    }
  }
}
